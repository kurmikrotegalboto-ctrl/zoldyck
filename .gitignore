# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel (keep project.json tracked so deploy doesn't switch project)
.vercel/*
!.vercel/project.json

# data directory (contains business KPI data & auth)
/data/

# Tool results (development artifacts)
tool-results/

# Database files
db/*.db

# Key files
*.key

# Download directory (screenshots, generated files)
/download/

# Examples (not for production)
/examples/

# Upload directory (business data files - KPI, PDF, APK)
/upload/


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# CLI artifacts
--timeout